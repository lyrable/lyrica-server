[Unit]
Description=LyricApp FastAPI Server
After=network.target

[Service]
User=lyrica
WorkingDirectory=/home/lyrica/lyrica-server/server
EnvironmentFile=/home/lyrica/lyrica-server/server/.env
ExecStart=/home/lyrica/lyrica-server/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
